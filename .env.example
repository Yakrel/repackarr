# ============================================
# Repackarr Configuration
# ============================================

# ============================================
# Timezone
# ============================================
TZ=Europe/Istanbul

# ============================================
# qBittorrent Connection (Required)
# ============================================
QBIT_HOST=http://192.168.1.100:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin
QBIT_CATEGORY=games

# ============================================
# Prowlarr Connection (Required)
# ============================================
PROWLARR_URL=http://192.168.1.100:9696
PROWLARR_API_KEY=your_prowlarr_api_key_here

# ============================================
# Dashboard Authentication (Optional)
# ============================================
# Leave empty to disable authentication
AUTH_USERNAME=
AUTH_PASSWORD=

# ============================================
# Scan Settings (Optional)
# ============================================
# How often to scan for updates (in minutes)
CRON_INTERVAL_MINUTES=60

# ============================================
# Filtering Settings (Optional)
# ============================================
# Comma-separated list of allowed platforms
PLATFORM_FILTER=Windows,Linux

# Comma-separated keywords to exclude from results
IGNORED_KEYWORDS=OST,Soundtrack,Wallpaper,Update Only,Crack Only

# Comma-separated tracker names to search (REQUIRED)
# Only these trackers will be searched in Prowlarr
# Example: NoNaMe Club, RuTracker.org
ALLOWED_INDEXERS=NoNaMe Club, RuTracker.org

# ============================================
# IGDB Integration (Optional)
# ============================================
# For game covers and metadata
# Get credentials at https://api-docs.igdb.com/
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
