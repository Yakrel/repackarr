# Repackarr Configuration

# qBittorrent connection
# Use the WebUI URL — same address you open in your browser
QBIT_HOST=http://192.168.1.100:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin
# Torrents must be in this category for Repackarr to detect them
QBIT_CATEGORY=games

# Prowlarr connection
PROWLARR_URL=http://192.168.1.100:9696
# Found in Prowlarr → Settings → General → API Key
PROWLARR_API_KEY=abc123def456abc123def456abc123de

# Optional: IGDB for game cover art and metadata
# Create an app at https://dev.twitch.tv/console → get Client ID + Secret
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Optional: Protect the Repackarr UI with a username/password
AUTH_USERNAME=
AUTH_PASSWORD=

# How often to auto-scan for updates (in minutes, default: 6 hours)
CRON_INTERVAL_MINUTES=360

# App data paths
# For the bundled Docker Compose file, these resolve inside the container as /app/data and /app/logs
DATA_DIR=./data
LOG_DIR=./logs
